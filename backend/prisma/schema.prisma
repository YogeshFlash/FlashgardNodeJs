model PlotterAssignmentLog {
  id             String        @id @default(uuid()) @db.Uuid
  plotterId      String        @map("plotter_id") @db.Uuid
  action         String        @db.VarChar(50)
  fromOwnerId    String?       @map("from_owner_id") @db.Uuid
  toOwnerId      String?       @map("to_owner_id") @db.Uuid
  fromLicenseId  String?       @map("from_license_id") @db.Uuid
  toLicenseId    String?       @map("to_license_id") @db.Uuid
  performedById  String        @map("performed_by_id") @db.Uuid
  notes          String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")

  plotter        Plotter       @relation(fields: [plotterId], references: [id], onDelete: Cascade)
  fromOwner      Organization? @relation("FromOwnerLogs", fields: [fromOwnerId], references: [id])
  toOwner        Organization? @relation("ToOwnerLogs", fields: [toOwnerId], references: [id])
  fromLicense    OrgLicense?   @relation("FromLicenseLogs", fields: [fromLicenseId], references: [id])
  toLicense      OrgLicense?   @relation("ToLicenseLogs", references: [id], fields: [toLicenseId])
  performedBy    User          @relation("PerformedLogs", fields: [performedById], references: [id])

  @@map("plotter_assignment_logs")
}






