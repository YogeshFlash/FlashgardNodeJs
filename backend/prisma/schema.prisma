model MachineCutLog {
  id             String  @id @default(uuid()) @db.Uuid
  appUniqueId    String? @map("app_unique_id") @db.VarChar(255)
  licenseId      String? @map("license_id") @db.Uuid
  modelId        String? @map("model_id") @db.Uuid
  modelCutFileId String? @map("model_cut_file_id") @db.Uuid
  organizationId String? @map("organization_id") @db.Uuid
  userId         String? @map("user_id") @db.Uuid

  brandName     String?  @map("brand_name") @db.VarChar(255)
  modelName     String?  @map("model_name") @db.VarChar(255)
  patternName   String?  @map("pattern_name") @db.VarChar(255)

  qrCode        String?  @map("qr_code") @db.VarChar(255)
  instruction   String?  @map("instruction") @db.Text
  plotterId     String?  @map("plotter_id") @db.VarChar(255)
  latitude      Float?
  longitude     Float?
  isPositiveCut Boolean  @default(true) @map("is_positive_cut")
  reviews       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  license      OrgLicense?   @relation(fields: [licenseId], references: [id])
  model        Model?        @relation(fields: [modelId], references: [id])
  modelCutFile ModelCutFile? @relation(fields: [modelCutFileId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([licenseId])
  @@index([appUniqueId])
  @@index([createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([licenseId, createdAt(sort: Desc)])
  @@map("machine_cut_logs")
}

